---
import Section from "@/components/ui/Section.astro";

const focus = [
  "LLM-powered systems",
  "RAG pipelines",
  "Agentic AI workflows",
  "Scalable ML infrastructure",
  "Conversational AI platforms",
  "NLP applications",
  "Robust API & backend design",
  "Model orchestration & serving",
  "Model fine-tuning & evaluation",
  "MLOps & model deployment",
  "Vector search & embeddings",
  "Predictive modeling",
];
---

<Section id="about" eyebrow="About" title="A Little About Me" headerClass="mb-6">
  <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr]">
    <div class="space-y-5 text-base leading-relaxed text-justify text-slate-600 dark:text-slate-300" data-reveal>
      <p>
        I'm a <span class="font-medium text-slate-900 dark:text-white">Software Developer at Kloudspot</span>, building
        intelligent applications that pair advanced AI with reliable backend engineering — specializing in LLM-powered
        systems, RAG pipelines, agentic AI, and scalable ML infrastructure. My foundation in
        <span class="font-medium text-slate-900 dark:text-white">Mathematics &amp; Computing</span> keeps me grounded in
        solving complex, real-world problems.
      </p>
      <p>
        My experience spans production-grade AI systems — conversational AI platforms, AI agents, retrieval-augmented
        generation, NLP applications, and machine learning services — built to be scalable, maintainable, and
        high-performance.
      </p>
      <p>
        I'm drawn to the intersection of generative AI, agentic workflows, and software engineering: orchestrating
        large language models, designing robust APIs, and turning cutting-edge research into practical products that
        deliver measurable value.
      </p>
      <p>
        Beyond building, I stay close to advances in AI, machine learning, and distributed systems — always
        experimenting and pushing the boundaries of what modern AI systems can achieve.
      </p>
    </div>

    <aside class="space-y-8" data-reveal style="--reveal-delay: 120ms">
      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
          Focus areas
        </h3>
        <ul class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-1">
          {
            focus.map((item) => (
              <li class="flex items-center gap-3 text-sm text-slate-700 dark:text-slate-200">
                <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-brand-500" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </aside>
  </div>
</Section>
