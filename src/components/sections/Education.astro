---
import Section from "@/components/ui/Section.astro";
import { education } from "@/data/credentials";
---

<Section id="education" eyebrow="Education" title="Academic foundation">
  <div class="grid gap-4">
    {
      education.map((e, i) => (
        <div
          class="group relative flex flex-col gap-4 overflow-hidden rounded-2xl border border-slate-200 bg-white/70 p-5 backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-brand-400/60 hover:shadow-2xl hover:shadow-brand-500/10 dark:border-white/10 dark:bg-white/[0.03] sm:flex-row sm:items-center sm:justify-between"
          data-reveal
          style={`--reveal-delay: ${i * 70}ms`}
        >
          {/* Top accent line — grows in on hover */}
          <span class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-gradient-to-r from-brand-500 via-accent-400 to-transparent transition-transform duration-500 group-hover:scale-x-100" />
          {/* Soft glow in the corner */}
          <span class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full bg-gradient-to-br from-brand-500/20 to-accent-400/10 opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100" />

          <div class="relative flex items-center gap-4">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center overflow-hidden rounded-xl border border-slate-200 bg-white p-1.5 dark:border-white/10">
              <img
                src={e.logo}
                alt={`${e.institution} logo`}
                loading="lazy"
                class="h-full w-full object-contain"
              />
            </div>
            <div class="min-w-0">
              <h3 class="font-display text-base font-semibold transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
                {e.credential}
              </h3>
              <p class="mt-0.5 text-sm text-slate-500 dark:text-slate-400">{e.institution}</p>
            </div>
          </div>

          <div class="relative flex items-center gap-3 pl-[4.5rem] sm:pl-0">
            <span class="chip border-brand-300/50 bg-brand-50 font-mono text-brand-700 dark:border-brand-500/30 dark:bg-brand-500/10 dark:text-brand-300">
              {e.score}
            </span>
            <span class="font-mono text-xs text-slate-400 dark:text-slate-500">{e.period}</span>
          </div>
        </div>
      ))
    }
  </div>
</Section>
