---
import Section from "@/components/ui/Section.astro";
import { getCollection } from "astro:content";

const all = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);

const githubIcon =
  "M12 .5C5.73.5.5 5.74.5 12.04c0 5.1 3.29 9.42 7.86 10.95.58.11.79-.25.79-.56v-2.02c-3.2.7-3.88-1.38-3.88-1.38-.53-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.78 2.7 1.26 3.36.97.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.5 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56A11.54 11.54 0 0 0 23.5 12.04C23.5 5.74 18.27.5 12 .5Z";
---

<Section
  id="projects"
  eyebrow="Projects"
  title="Featured Projects"
  subtitle="A mix of shipped platforms and open-source side projects. Each card opens the problem, the architecture, and the impact."
>
  <div class="grid gap-6 lg:grid-cols-2" id="project-grid">
    {
      all.map((p, i) => (
        <article
          class:list={[
            "project-card group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white/70 p-6 backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-brand-400/60 hover:shadow-2xl hover:shadow-brand-500/10 dark:border-white/10 dark:bg-white/[0.03]",
            p.data.featured && "lg:col-span-2",
          ]}
          data-reveal
          style={`--reveal-delay: ${i * 60}ms`}
        >
          {/* Top accent line — grows in on hover */}
          <span class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-gradient-to-r from-brand-500 via-accent-400 to-transparent transition-transform duration-500 group-hover:scale-x-100" />
          {/* Soft glow in the corner */}
          <span class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full bg-gradient-to-br from-brand-500/20 to-accent-400/10 opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100" />

          <div class="relative flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                {p.data.featured && (
                  <span class="chip border-brand-300/50 bg-brand-50 font-mono text-brand-700 dark:border-brand-500/30 dark:bg-brand-500/10 dark:text-brand-300">
                    ★ Featured
                  </span>
                )}
                {p.data.tags.map((t) => (
                  <span class="chip font-mono">{t}</span>
                ))}
              </div>
              <h3 class="mt-3 font-display text-xl font-bold transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
                {p.data.title}
              </h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{p.data.tagline}</p>
            </div>
            <div class="flex shrink-0 gap-2">
              {p.data.github && (
                <a
                  href={p.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={p.data.githubUi ? `${p.data.title} backend repo on GitHub` : `${p.data.title} on GitHub`}
                  title={p.data.githubUi ? "Backend repo" : "GitHub"}
                  class="flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 text-slate-500 transition-colors hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-white/10 dark:text-slate-400 dark:hover:text-brand-300"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d={githubIcon} /></svg>
                </a>
              )}
              {p.data.githubUi && (
                <a
                  href={p.data.githubUi}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${p.data.title} UI repo on GitHub`}
                  title="UI repo"
                  class="flex h-9 items-center justify-center gap-1.5 rounded-lg border border-slate-200 px-2.5 text-slate-500 transition-colors hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-white/10 dark:text-slate-400 dark:hover:text-brand-300"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d={githubIcon} /></svg>
                  <span class="font-mono text-xs font-medium">UI</span>
                </a>
              )}
              {p.data.demo && (
                <a
                  href={p.data.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${p.data.title} live demo`}
                  class="flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 text-slate-500 transition-colors hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-white/10 dark:text-slate-400 dark:hover:text-brand-300"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              )}
            </div>
          </div>

          {/* Problem / Architecture — hairline-divided panel */}
          <div class="mt-5 grid gap-px overflow-hidden rounded-xl border border-slate-200/70 bg-slate-200/60 text-sm dark:border-white/10 dark:bg-white/10 sm:grid-cols-2">
            <div class="bg-white/70 p-4 dark:bg-slate-950/30">
              <p class="section-eyebrow flex items-center gap-1.5 !text-[0.65rem]">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand-500" />
                Problem
              </p>
              <p class="mt-2 text-slate-600 dark:text-slate-300">{p.data.problem}</p>
            </div>
            <div class="bg-white/70 p-4 dark:bg-slate-950/30">
              <p class="section-eyebrow flex items-center gap-1.5 !text-[0.65rem]">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-500" />
                Architecture
              </p>
              <p class="mt-2 text-slate-600 dark:text-slate-300">{p.data.architecture}</p>
            </div>
          </div>

          <details class="group/details mt-4">
            <summary class="flex cursor-pointer list-none items-center gap-1.5 text-sm font-medium text-brand-600 transition-colors hover:text-brand-500 dark:text-brand-400">
              <svg class="h-4 w-4 transition-transform group-open/details:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Key achievements
            </summary>
            <ul class="mt-3 space-y-2 pl-1">
              {p.data.highlights.map((h) => (
                <li class="flex gap-2.5 text-sm text-slate-600 dark:text-slate-300">
                  <svg class="mt-1 h-3.5 w-3.5 shrink-0 text-accent-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </details>

          <div class="mt-auto flex flex-wrap gap-1.5 border-t border-slate-200/70 pt-5 dark:border-white/10">
            {p.data.tech.map((t) => (
              <span class="chip font-mono">{t}</span>
            ))}
          </div>
        </article>
      ))
    }
  </div>

</Section>
