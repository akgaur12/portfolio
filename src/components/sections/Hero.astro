---
import { site, socials } from "@/data/site";

// Bold the leading role phrase, keep the rest of the tagline dynamic
const [taglineLead, ...taglineRest] = site.tagline.split(",");
// Break the closing "Passionate about…" sentence onto its own line
const [taglineTail, taglinePassion = ""] = taglineRest.join(",").split(/(?=Passionate)/);
---

<section id="top" class="relative flex min-h-screen items-center pt-28 pb-16">
  <div class="container-page">
    <div class="grid items-center gap-12 lg:grid-cols-[1.4fr_1fr]">
      <!-- Profile / visual -->
      <div class="relative mx-auto w-full max-w-[18rem] lg:order-last" style="animation: var(--animate-fade-up); animation-delay: 200ms">
        <div class="relative aspect-square">
          <!-- Soft glow behind the circle -->
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-brand-500/40 to-accent-500/40 blur-3xl"></div>
          <!-- Rotating gradient ring -->
          <div class="profile-ring absolute inset-0 rounded-full bg-gradient-to-tr from-brand-500 via-accent-500 to-brand-400 p-[3px]">
            <div
              class="relative flex h-full w-full items-center justify-center overflow-hidden rounded-full bg-white dark:bg-slate-900"
            >
              <img
                src="/profile.jpg"
                alt={`Portrait of ${site.name}`}
                loading="eager"
                class="h-full w-full rounded-full object-cover"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
              />
              <div class="hidden h-full w-full items-center justify-center rounded-full bg-gradient-to-br from-brand-600 to-accent-600 font-display text-7xl font-bold text-white">
                AG
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Copy -->
      <div>
        <div
          class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/60 px-4 py-1.5 text-xs font-medium text-slate-600 backdrop-blur dark:border-white/10 dark:bg-white/5 dark:text-slate-300"
          style="animation: var(--animate-fade-up); animation-delay: 0ms"
        >
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
          </span>
          {site.availability}
        </div>

        <h1
          class="mt-6 font-display text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl"
          style="animation: var(--animate-fade-up); animation-delay: 80ms"
        >
          <span data-type-prefix>Hi, I'm </span><span class="text-gradient" data-type-name>{site.name}</span><span
            class="type-cursor"
            aria-hidden="true">|</span>
        </h1>

        <p
          class="mt-6 max-w-xl text-lg text-justify text-slate-600 dark:text-slate-300"
          style="animation: var(--animate-fade-up); animation-delay: 160ms"
        >
          <span class="font-semibold text-slate-900 dark:text-white">{taglineLead}</span>,{taglineTail}
          {taglinePassion && <span class="mt-1 block">{taglinePassion}</span>}
        </p>

        <div
          class="mt-8 flex flex-wrap items-center gap-3"
          style="animation: var(--animate-fade-up); animation-delay: 240ms"
        >
          <a href="#projects" class="btn-primary">
            View my work
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14m-6-6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          <a href="#contact" class="btn-ghost">Get in touch</a>
        </div>

        <div
          class="mt-8 flex items-center gap-3"
          style="animation: var(--animate-fade-up); animation-delay: 320ms"
        >
          {
            socials.map((s) => (
              <a
                href={s.href}
                target={s.label === "Email" ? undefined : "_blank"}
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 text-slate-500 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-white/10 dark:text-slate-400 dark:hover:text-brand-300"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={s.icon} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .type-cursor {
    display: inline-block;
    margin-left: 0.05em;
    font-weight: 300;
    color: var(--color-brand-500);
    animation: cursor-blink 1s step-end infinite;
  }
  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }
  .type-cursor--done {
    display: none;
  }
  .profile-ring {
    background-size: 200% 200%;
    animation: ring-shift 6s ease infinite;
  }
  @keyframes ring-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .profile-ring {
      animation: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .type-cursor {
      display: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const prefix = document.querySelector("[data-type-prefix]");
    const name = document.querySelector("[data-type-name]");
    const cursor = document.querySelector(".type-cursor");
    if (!prefix || !name) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    // Type prefix, then name, then hide the cursor
    const segments = [prefix, name].map((el) => ({ el, full: el.textContent || "" }));
    segments.forEach((s) => (s.el.textContent = ""));

    let seg = 0;
    let i = 0;
    const tick = () => {
      const { el, full } = segments[seg];
      el.textContent = full.slice(0, ++i);
      if (i < full.length) {
        setTimeout(tick, 95);
      } else if (seg < segments.length - 1) {
        seg++;
        i = 0;
        setTimeout(tick, 95);
      } else if (cursor) {
        setTimeout(() => cursor.classList.add("type-cursor--done"), 600);
      }
    };
    setTimeout(tick, 450);
  })();
</script>
