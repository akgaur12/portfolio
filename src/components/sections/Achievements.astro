---
import Section from "@/components/ui/Section.astro";
import { achievements } from "@/data/credentials";

const kindMeta: Record<string, { label: string; icon: string }> = {
  exam: { label: "Exam", icon: "M12 14l9-5-9-5-9 5 9 5Zm0 0v7m-6-3.5V12" },
  research: { label: "Research", icon: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z" },
  hackathon: { label: "Leadership", icon: "M13 2 3 14h7l-1 8 10-12h-7l1-8Z" },
  award: { label: "Award", icon: "M12 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm-3 .5L7 22l5-2 5 2-2-6.5" },
};
---

<Section
  id="achievements"
  eyebrow="Achievements"
  title="Recognition & credentials"
  subtitle="Competitive exams, published research, and leadership milestones."
>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      achievements.map((a, i) => (
        <div class="card flex gap-4 p-5" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/15 to-accent-500/15 text-brand-600 dark:text-brand-400">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d={kindMeta[a.kind].icon} stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h3 class="font-display text-base font-semibold">{a.title}</h3>
              <span class="chip font-mono">{a.year}</span>
            </div>
            <p class="mt-1.5 text-sm text-slate-500 dark:text-slate-400">{a.detail}</p>
          </div>
        </div>
      ))
    }
  </div>
</Section>
