---
import Section from "@/components/ui/Section.astro";
import { experience } from "@/data/experience";
---

<Section
  id="experience"
  eyebrow="Experience"
  title="What I've built at Kloudspot"
  subtitle="From early proofs of concept to flagship GenAI platforms in production — here's the throughline."
>
  <div class="relative">
    <!-- Timeline spine -->
    <div class="absolute left-4 top-2 bottom-2 w-px bg-gradient-to-b from-brand-500 via-brand-400/40 to-transparent sm:left-5"></div>

    <div class="space-y-12">
      {
        experience.map((job) => (
          <div class="relative pl-12 sm:pl-16" data-reveal>
            <span class="absolute left-2 top-1.5 flex h-5 w-5 items-center justify-center sm:left-3">
              <span class="absolute h-5 w-5 rounded-full bg-brand-500/20"></span>
              <span class:list={["relative h-2.5 w-2.5 rounded-full", job.current ? "bg-emerald-500" : "bg-brand-500"]} />
            </span>

            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h3 class="font-display text-xl font-semibold">{job.role}</h3>
              <span class="text-brand-600 dark:text-brand-400">·</span>
              <span class="font-medium text-slate-700 dark:text-slate-200">{job.company}</span>
              {job.current && (
                <span class="chip border-emerald-300/50 bg-emerald-50 text-emerald-700 dark:border-emerald-500/30 dark:bg-emerald-500/10 dark:text-emerald-300">
                  Current
                </span>
              )}
            </div>
            <p class="mt-1 font-mono text-xs text-slate-500 dark:text-slate-400">{job.period}</p>
            {job.blurb && <p class="mt-3 max-w-2xl text-sm text-slate-600 dark:text-slate-300">{job.blurb}</p>}

            <div class="mt-5 grid gap-4">
              {job.highlights.map((h) => (
                <div class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white/70 p-5 backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-brand-400/60 hover:shadow-2xl hover:shadow-brand-500/10 dark:border-white/10 dark:bg-white/[0.03]">
                  {/* Top accent line — grows in on hover */}
                  <span class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-gradient-to-r from-brand-500 via-accent-400 to-transparent transition-transform duration-500 group-hover:scale-x-100" />
                  {/* Soft glow in the corner */}
                  <span class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full bg-gradient-to-br from-brand-500/20 to-accent-400/10 opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100" />
                  <h4 class="relative font-display text-sm font-semibold text-slate-900 transition-colors group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">{h.title}</h4>
                  <ul class="relative mt-3 space-y-2">
                    {h.points.map((p) => (
                      <li class="flex gap-2.5 text-sm text-slate-600 dark:text-slate-300">
                        <svg class="mt-1 h-3.5 w-3.5 shrink-0 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                          <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span>{p}</span>
                      </li>
                    ))}
                  </ul>
                  {h.tech && (
                    <div class="relative mt-4 flex flex-wrap gap-1.5">
                      {h.tech.map((t) => (
                        <span class="chip font-mono">{t}</span>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>
