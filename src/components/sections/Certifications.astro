---
import Section from "@/components/ui/Section.astro";
import { certifications } from "@/data/credentials";
---

<Section
  id="certifications"
  eyebrow="Certifications"
  title="Certifications"
  subtitle="Courses and credentials I've earned along the way — browse the carousel and click any card to view the full certificate."
>
  <div class="overflow-hidden">
    <div id="cert-track" class="flex gap-6 transition-transform duration-500 ease-out will-change-transform">
    {
      certifications.map((c, i) => (
        <button
          type="button"
          class="cert-card group relative flex w-full shrink-0 flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white/70 text-left backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-brand-400/60 hover:shadow-2xl hover:shadow-brand-500/10 dark:border-white/10 dark:bg-white/[0.03] sm:w-[calc((100%-1.5rem)/2)] lg:w-[calc((100%-3rem)/3)]"
          data-cert-src={c.image}
          data-cert-name={c.name}
          data-reveal
          style={`--reveal-delay: ${i * 60}ms`}
        >
          {/* Top accent line — grows in on hover */}
          <span class="absolute inset-x-0 top-0 z-10 h-px origin-left scale-x-0 bg-gradient-to-r from-brand-500 via-accent-400 to-transparent transition-transform duration-500 group-hover:scale-x-100" />
          <div class="aspect-[4/3] overflow-hidden bg-slate-100 dark:bg-white/5">
            <img
              src={c.image}
              alt={`${c.name} certificate`}
              loading="lazy"
              class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="flex items-center justify-between gap-3 border-t border-slate-200/70 p-4 dark:border-white/10">
            <div class="min-w-0">
              <h3 class="truncate font-display text-sm font-semibold text-slate-900 transition-colors group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
                {c.name}
              </h3>
              {(c.issuer || c.year) && (
                <p class="mt-0.5 font-mono text-xs text-slate-400 dark:text-slate-500">
                  {[c.issuer, c.year].filter(Boolean).join(" · ")}
                </p>
              )}
            </div>
            <svg
              class="h-4 w-4 shrink-0 text-slate-400 transition-colors group-hover:text-brand-500 dark:text-slate-500"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M15 3h6m0 0v6m0-6L14 10M9 21H3m0 0v-6m0 6 7-7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        </button>
      ))
    }
    </div>
  </div>

  {/* Carousel controls */}
  <div class="mt-8 flex items-center justify-center gap-4" data-reveal>
    <button
      id="cert-prev"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-600 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-white/10 dark:text-slate-300 dark:hover:text-brand-300"
      aria-label="Previous certificate"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m15 18-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <div id="cert-dots" class="flex items-center gap-2"></div>
    <button
      id="cert-next"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-600 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-white/10 dark:text-slate-300 dark:hover:text-brand-300"
      aria-label="Next certificate"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>

  {/* Lightbox */}
  <div
    id="cert-lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/85 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Certificate preview"
  >
    <button
      id="cert-close"
      type="button"
      class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition-colors hover:bg-white/10"
      aria-label="Close certificate preview"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 6l12 12M6 18 18 6" stroke-linecap="round" />
      </svg>
    </button>
    <figure class="flex max-h-[90vh] w-full max-w-5xl flex-col items-center gap-3">
      <img id="cert-img" src="" alt="" class="max-h-[80vh] w-auto rounded-lg shadow-2xl" />
      <figcaption id="cert-caption" class="font-mono text-sm text-white/80"></figcaption>
    </figure>
  </div>
</Section>

<script is:inline>
  (() => {
    const track = document.getElementById("cert-track");
    if (!track) return;
    const cards = Array.from(track.children);
    const prev = document.getElementById("cert-prev");
    const next = document.getElementById("cert-next");
    const dotsWrap = document.getElementById("cert-dots");
    let index = 0;
    let dots = [];

    const perView = () =>
      window.innerWidth >= 1024 ? 3 : window.innerWidth >= 640 ? 2 : 1;
    const maxIndex = () => Math.max(0, cards.length - perView());

    const buildDots = () => {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = "";
      dots = [];
      const count = maxIndex() + 1;
      for (let k = 0; k < count; k++) {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "h-2 rounded-full transition-all duration-300";
        b.setAttribute("aria-label", "Go to slide " + (k + 1));
        b.addEventListener("click", () => {
          index = k;
          update();
        });
        dotsWrap.appendChild(b);
        dots.push(b);
      }
    };

    const update = () => {
      const m = maxIndex();
      if (index > m) index = 0;
      if (index < 0) index = m;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.columnGap || style.gap || "0") || 0;
      const w = cards[0].getBoundingClientRect().width;
      track.style.transform = "translateX(-" + index * (w + gap) + "px)";
      dots.forEach((d, k) => {
        const active = k === index;
        d.classList.toggle("w-6", active);
        d.classList.toggle("bg-brand-500", active);
        d.classList.toggle("w-2", !active);
        d.classList.toggle("bg-slate-300", !active);
        d.classList.toggle("dark:bg-white/20", !active);
      });
    };

    prev?.addEventListener("click", () => {
      index--;
      update();
    });
    next?.addEventListener("click", () => {
      index++;
      update();
    });

    let rt;
    window.addEventListener("resize", () => {
      clearTimeout(rt);
      rt = setTimeout(() => {
        buildDots();
        if (index > maxIndex()) index = maxIndex();
        update();
      }, 150);
    });

    buildDots();
    update();
  })();
</script>

<script is:inline>
  (() => {
    const lb = document.getElementById("cert-lightbox");
    const img = document.getElementById("cert-img");
    const cap = document.getElementById("cert-caption");
    const closeBtn = document.getElementById("cert-close");
    if (!lb || !img) return;

    const open = (src, name) => {
      img.setAttribute("src", src || "");
      img.setAttribute("alt", (name || "") + " certificate");
      if (cap) cap.textContent = name || "";
      lb.classList.remove("hidden");
      lb.classList.add("flex");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      lb.classList.add("hidden");
      lb.classList.remove("flex");
      img.setAttribute("src", "");
      document.body.style.overflow = "";
    };

    document.querySelectorAll(".cert-card").forEach((c) => {
      c.addEventListener("click", () =>
        open(c.getAttribute("data-cert-src"), c.getAttribute("data-cert-name"))
      );
    });
    closeBtn?.addEventListener("click", close);
    lb.addEventListener("click", (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lb.classList.contains("hidden")) close();
    });
  })();
</script>
