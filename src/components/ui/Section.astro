---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  subtitle?: string;
  class?: string;
  headerClass?: string;
}
const { id, eyebrow, title, subtitle, class: className = "", headerClass = "mb-12" } = Astro.props;
---

<section id={id} class:list={["scroll-mt-24 py-20 sm:py-28", className]}>
  <div class="container-page">
    <header class:list={["max-w-2xl", headerClass]} data-reveal>
      <p class="section-eyebrow">{eyebrow}</p>
      <h2 class="mt-3 text-3xl font-bold sm:text-4xl">{title}</h2>
      {subtitle && <p class="mt-4 text-base text-slate-500 dark:text-slate-400">{subtitle}</p>}
    </header>
    <slot />
  </div>
</section>
