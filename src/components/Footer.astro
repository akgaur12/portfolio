---
import { site, socials, navLinks } from "@/data/site";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-slate-200 py-12 dark:border-white/10">
  <div class="container-page flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
    <div class="max-w-sm">
      <a href="#top" class="font-display text-lg font-bold text-slate-900 dark:text-white">
        Akash Gaur<span class="text-brand-500">.</span>
      </a>
      <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">{site.tagline}</p>
      <div class="mt-4 flex gap-3">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target={s.label === "Email" ? undefined : "_blank"}
              rel="noopener noreferrer"
              aria-label={s.label}
              class="flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 text-slate-500 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-white/10 dark:text-slate-400 dark:hover:text-brand-300"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={s.icon} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>

    <nav class="flex flex-col gap-2" aria-label="Footer">
      <span class="section-eyebrow mb-1">Navigate</span>
      {
        navLinks.map((l) => (
          <a href={l.href} class="text-sm text-slate-500 transition-colors hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-300">
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="container-page mt-10 flex flex-col items-center justify-between gap-2 border-t border-slate-200 pt-6 text-xs text-slate-400 dark:border-white/10 sm:flex-row">
    <p>© {year} {site.name}. All rights reserved.</p>
    <p>Built with <span class="font-medium text-slate-500 dark:text-slate-300">Astro</span> &amp; <span class="font-medium text-slate-500 dark:text-slate-300">Tailwind CSS</span>.</p>
  </div>
</footer>
