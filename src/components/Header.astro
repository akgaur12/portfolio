---
import { site, navLinks } from "@/data/site";
import ThemeToggle from "@/components/ThemeToggle.astro";
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-40 transition-all duration-300"
  data-scrolled="false"
>
  <div
    class="container-page mt-3 flex items-center justify-between rounded-2xl border border-transparent px-4 py-3 transition-all duration-300"
    id="header-inner"
  >
    <a href="#top" class="group flex items-center gap-2 font-display text-lg font-bold tracking-tight">
      <span
        class="flex h-9 w-9 items-center justify-center rounded-xl bg-brand-600 font-mono text-sm text-white shadow-lg shadow-brand-600/30 transition-transform group-hover:scale-105"
        >AG</span
      >
      <span class="text-slate-900 dark:text-white">Akash<span class="text-brand-500">.</span></span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:text-brand-600 dark:text-slate-300 dark:hover:text-brand-300"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={site.resumeUrl}
        class="btn-ghost hidden px-3 py-2 text-xs sm:inline-flex"
        download
        aria-label="Download résumé (PDF)"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 3v12m0 0 4-4m-4 4-4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        Résumé
      </a>
      <ThemeToggle />
      <button
        id="menu-btn"
        class="btn-ghost p-2 md:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path id="menu-open" d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"></path>
          <path id="menu-close" class="hidden" d="M6 6l12 12M6 18 18 6" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="container-page hidden md:!hidden"
    aria-label="Mobile"
  >
    <div class="card mt-2 flex flex-col gap-1 p-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-link rounded-lg px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-white/5"
          >
            {link.label}
          </a>
        ))
      }
      <a href={site.resumeUrl} download class="btn-primary mt-1">Download Résumé</a>
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const inner = document.getElementById("header-inner");
    const onScroll = () => {
      const scrolled = window.scrollY > 16;
      if (!inner) return;
      inner.classList.toggle("border-slate-200/70", scrolled);
      inner.classList.toggle("dark:border-white/10", scrolled);
      inner.classList.toggle("bg-white/80", scrolled);
      inner.classList.toggle("dark:bg-slate-950/70", scrolled);
      inner.classList.toggle("backdrop-blur-xl", scrolled);
      inner.classList.toggle("shadow-lg", scrolled);
      inner.classList.toggle("shadow-slate-900/5", scrolled);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Mobile menu
    const btn = document.getElementById("menu-btn");
    const nav = document.getElementById("mobile-nav");
    const openIcon = document.getElementById("menu-open");
    const closeIcon = document.getElementById("menu-close");
    const toggle = (force) => {
      if (!nav || !btn) return;
      const willOpen = force ?? nav.classList.contains("hidden");
      nav.classList.toggle("hidden", !willOpen);
      btn.setAttribute("aria-expanded", String(willOpen));
      openIcon?.classList.toggle("hidden", willOpen);
      closeIcon?.classList.toggle("hidden", !willOpen);
    };
    btn?.addEventListener("click", () => toggle());
    nav?.querySelectorAll(".mobile-link, .btn-primary").forEach((a) =>
      a.addEventListener("click", () => toggle(false))
    );

    // Scroll-spy for active nav link
    const links = Array.from(document.querySelectorAll(".nav-link"));
    const map = new Map();
    links.forEach((l) => {
      const id = l.getAttribute("href")?.slice(1);
      if (id) map.set(id, l);
    });
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          const link = map.get(e.target.id);
          if (!link) return;
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove("text-brand-600", "dark:text-brand-300"));
            link.classList.add("text-brand-600", "dark:text-brand-300");
          }
        });
      },
      { rootMargin: "-45% 0px -50% 0px" }
    );
    map.forEach((_, id) => {
      const sec = document.getElementById(id);
      if (sec) spy.observe(sec);
    });
  })();
</script>
